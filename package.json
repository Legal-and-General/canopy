{
  "name": "@legal-and-general/canopy",
  "version": "0.0.0",
  "license": "Apache-2.0",
  "url": "git://github.com/Legal-and-General/canopy.git",
  "repository": "https://github.com/Legal-and-General/canopy",
  "type": "module",
  "scripts": {
    "// ----- STORYBOOK": "",
    "start": "npm run generate:css-variables && npm run build && ng run canopy:storybook",
    "build:storybook": "npm run generate:css-variables && ng run canopy:build-storybook",
    "// ----- BUILD LIB": "",
    "build": "npm run build:icons && ng build canopy && npm run build:styles",
    "build:icons": "npm run optimise:svgs && npm run generate:icons && npm run generate:pictograms && npm run generate:flag-icons && npm run generate:icon-loader",
    "build:styles": "webpack --config webpack.global.config.js",
    "// ----- GENERATE": "",
    "generate:icons": "svg-to-ts-files --config svg-to-ts-icons.config.json",
    "generate:pictograms": "svg-to-ts-files --config svg-to-ts-pictograms.config.json",
    "generate:flag-icons": "svg-to-ts-files --config svg-to-ts-flag-icons.config.json",
    "generate:icon-loader": "node scripts/generate-icon-loader.js",
    "generate:css-variables": "node scripts/generate-css-variables.js",
    "// ----- TEST": "",
    "test": "jest",
    "test:ci": "jest --ci --workers=2",
    "test:ws": "npx jest --config=.github/workflow-scripts/jest.config.js --coverage",
    "test:visual": "npm run build && npm run build:storybook && npx percy storybook ./storybook-static",
    "// ----- LINTING AND OPTIMISATION": "",
    "eslint": "ng lint --quiet",
    "lint": "npm run eslint && npm run stylelint",
    "optimise:svgs": "svgo projects/canopy/src/assets/icons -r --config=svgo-icons.config.js && svgo projects/canopy/src/assets/pictograms -r --config=svgo-pictograms.config.js && svgo projects/canopy/src/assets/flag-icons -r --config=svgo-flag-icons.config.js",
    "stylelint": "stylelint \"projects/**/*.scss\"",
    "// ----- TEST APP": "",
    "build:test-app": "npm run build && ng build canopy-test-app --configuration production --output-path ./test-dist",
    "start:test-app": "ng serve",
    "test:test-app": "ng test canopy-test-app",
    "// ----- MISC": "",
    "commit": "npx git-cz",
    "docs:json": "compodoc -p ./tsconfig.json --disablePrivate -e json -d .",
    "license-check:build": "npx license-checker --summary --start dist/canopy --onlyAllow 'MIT;Apache-2.0;0BSD'",
    "prepare": "husky"
  },
  "engines": {
    "node": ">=24.18.0"
  },
  "private": false,
  "overrides": {
    "qs": "6.15.0",
    "undici": "7.28.0",
    "vite": "7.3.2"
  },
  "dependencies": {
    "@angular/animations": "21.2.17",
    "@angular/cdk": "21.2.14",
    "@angular/common": "21.2.17",
    "@angular/compiler": "21.2.17",
    "@angular/core": "21.2.17",
    "@angular/forms": "21.2.17",
    "@angular/platform-browser": "21.2.17",
    "@angular/platform-browser-dynamic": "21.2.17",
    "@angular/router": "21.2.17",
    "@legal-and-general/canopy-design-tokens": "1.21.0",
    "date-fns": "4.1.0",
    "rxjs": "7.8.2",
    "tslib": "2.8.1",
    "zone.js": "0.15.1"
  },
  "devDependencies": {
    "@angular-builders/jest": "21.0.4",
    "@angular-devkit/build-angular": "21.2.15",
    "@angular-eslint/builder": "21.4.0",
    "@angular-eslint/eslint-plugin": "21.4.0",
    "@angular-eslint/eslint-plugin-template": "21.4.0",
    "@angular-eslint/schematics": "21.4.0",
    "@angular-eslint/template-parser": "21.4.0",
    "@angular/cli": "21.2.15",
    "@angular/compiler-cli": "21.2.17",
    "@angular/language-service": "21.2.17",
    "@commitlint/cli": "21.0.1",
    "@commitlint/config-angular": "21.0.1",
    "@commitlint/config-conventional": "21.0.1",
    "@commitlint/prompt": "21.0.1",
    "@compodoc/compodoc": "1.2.1",
    "@percy/cli": "1.32.2",
    "@percy/storybook": "10.0.0",
    "@semantic-release/github": "12.0.8",
    "@semantic-release/npm": "13.1.5",
    "@storybook/addon-a11y": "10.4.0",
    "@storybook/addon-docs": "10.4.0",
    "@storybook/angular": "10.4.0",
    "@stylelint/postcss-css-in-js": "0.38.0",
    "@stylelint/postcss-markdown": "0.36.2",
    "@stylistic/eslint-plugin": "5.10.0",
    "@types/jest": "30.0.0",
    "@types/node": "25.8.0",
    "@typescript-eslint/eslint-plugin": "8.58.2",
    "@typescript-eslint/parser": "8.58.2",
    "@typescript-eslint/utils": "8.58.2",
    "autoprefixer": "10.5.0",
    "color-convert": "3.1.3",
    "commitizen": "4.3.1",
    "copy-webpack-plugin": "14.0.0",
    "cz-conventional-changelog": "3.3.0",
    "eslint": "9.39.4",
    "eslint-plugin-html": "8.1.4",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-jest": "29.15.2",
    "eslint-plugin-storybook": "10.3.5",
    "eslint-plugin-unused-imports": "4.4.1",
    "fs-extra": "11.3.4",
    "globals": "17.6.0",
    "husky": "9.1.7",
    "jest": "30.3.0",
    "jest-environment-jsdom": "30.3.0",
    "jest-marbles": "3.1.1",
    "jest-preset-angular": "16.2.0",
    "license-checker": "25.0.1",
    "lint-staged": "16.4.0",
    "mini-css-extract-plugin": "2.10.2",
    "ng-mocks": "14.15.3",
    "ng-packagr": "21.2.5",
    "npm": "11.14.1",
    "postcss": "8.5.9",
    "postcss-scss": "4.0.9",
    "prettier": "3.8.2",
    "remark-gfm": "4.0.1",
    "sass": "1.99.0",
    "semantic-release": "25.0.3",
    "storybook": "10.4.0",
    "storybook-addon-tag-badges": "3.1.0",
    "stylelint": "17.11.1",
    "stylelint-config-recommended": "18.0.0",
    "stylelint-selector-bem-pattern": "4.0.1",
    "svg-to-ts": "12.0.0",
    "svgo": "4.0.1",
    "ts-node": "10.9.2",
    "typescript": "~5.9.3",
    "webpack": "5.106.1",
    "webpack-cli": "7.0.2",
    "webpack-remove-empty-scripts": "1.1.1"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  }
}
